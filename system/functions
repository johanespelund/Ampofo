linesample
{
  type sets;
  libs (sampling);
  writeControl writeTime;
  writeInterval 1;
  interpolationScheme cellPointFace;
  setFormat csv;
  sets
    (
    vertical
    {
      type lineFace;
      axis z;
      start ($x_mid $x_mid -1e3);
      end ($x_mid $x_mid 1e3);
    }
    horizontal
    {
      type lineFace;
      axis x;
      start (-1e3 $x_mid $x_mid);
      end (1e3 $x_mid $x_mid);
    }
    );
  fields (T p U rho k thermo:mu TMean UMean rhoMean kMean nutMean);
}

