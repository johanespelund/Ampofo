FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../parameters"

solvers
{
    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       0;
        relTol          0;
    }
    "f.*"
    {
        solver          PBiCGStab;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.0;
        // minIter        1;
    }

    "(p_rgh|cellDisplacement)"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-12;
        relTol          0.01;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|h|e|k|v2|epsilon|R|omega|gammaInt|ReThetat)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-10;
        relTol          0.1;
        minIter        1;
    }

    "(U|h|e|k|v2|epsilon|R|omega|gammaInt|ReThetat)Final"
    {
        $U;
        relTol          0;
    }
    // f
    // {
    //     solver          PBiCGStab;
    //     preconditioner  DIC;
    //     tolerance       1e-10;
    //     relTol          0.0;
    //     minIter        1;
    // }

}

PIMPLE
{
    momentumPredictor   no;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
    pRefCell            0;
    pRefValue           1e5;
    ddtCorr             true;
    // turbOnFinalIterOnly false;
    maxCo              $maxCo;
    maxDeltaT          10;
    rDeltaTSmoothingCoeff 0.05;
    rDeltaTDampingCoeff 1;

