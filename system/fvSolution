FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../parameters"

solvers
{
    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       0;
        relTol          0;
    }
    "f.*"
    {
        solver          PBiCGStab;
        preconditioner  DIC;
        tolerance       1e-20;
        relTol          0.0;
        minIter        1;
    }

    "(p_rgh|cellDisplacement)"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-20;
        relTol          0.0;
        // solver          GAMG;
        // smoother        DIC;
        // tolerance       1e-6;
        // relTol          0.01;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|h|e|k|phit|v2|epsilon|R|omega|gammaInt|ReThetat)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-20;
        relTol          0.0;
        minIter        1;
    }

    "(U|h|e|k|phit|v2|epsilon|R|omega|gammaInt|ReThetat)Final"
    {
        $U;
        relTol          0;
    }
    // f
    // {
    //     solver          PBiCGStab;
    //     preconditioner  DIC;
    //     tolerance       1e-10;
    //     relTol          0.0;
    //     minIter        1;
    // }
    pcorr
    {
      $p_rgh;
    }
        "ebf.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-20;
        relTol          0.0;
    }

}

PIMPLE
{
    momentumPredictor   yes;
    nOuterCorrectors    $nOuterCorrectors;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
    pRefCell            0;
    pRefValue           101325;
    ddtCorr             true;
    turbOnFinalIterOnly false;
    // maxCo              $maxCo;
    // maxDeltaT          10;
    rDeltaTSmoothingCoeff 0.05;
    rDeltaTDampingCoeff 1;
    consistent $consistent;

      outerCorrectorResidualControl
      {
          "(p_rgh|e|h)"
          {
              tolerance       1e-3;
              relTol          0;
          }
          U
          {
            tolerance 1e-2;
            relTol    0;
          }
      }

}

relaxationFactors
{
  fields
  {
    ".*" 1;
  }
  equations
  {
    U   0.9;
    "(h|e)"   1;
    "(k|epsilon|omega|phit|v2|f|ebf)" 0.8;
    ".*Final" 1;
  }
}
