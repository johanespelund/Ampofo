FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


#include "../parameters"

simulationType          $simulationType;

RAS
{
  RASModel            $RASModel;

  turbulence          $turbulence;

  printCoeffs         on;

  buoyantKEpsilonCoeffs
  {
    Cg $Cg; // Corresponds to Prt = 0.85 (Cg = 1/Prt)
  }
  v2fBuoyantCoeffs
  {
    Cg $Cg; // Corresponds to Prt = 0.85 (Cg = 1/Prt)
    THFM  $THFM;
  }
}

