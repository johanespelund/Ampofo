FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


#include "../parameters"

simulationType          $simulationType;

RAS
{
  RASModel            $RASModel;

  turbulence          $turbulence;

  printCoeffs         on;

  buoyantKEpsilonCoeffs
  {
    Cg $Cg; // Corresponds to Prt = 0.90 (Cg = 1/Prt)
  }
  phitfBuoyantCoeffs
  {
    Cg $Cg;
    THFM  $THFM;
    kEqnSource true;
    epsEqnSource true;
    phitEqnSource false;
    fEqnSource false;
  }
  v2fBuoyantCoeffs
  {
    Cg $Cg;
    THFM  $THFM;
    kEqnSource true;
    epsEqnSource true;
    v2EqnSource true;
    fEqnSource false;
  }
  kEpsilonEBCoeffs
  {
    Cg $Cg;
    THFM  $THFM;
    // kEqnSource true;
    // epsEqnSource true;
    // v2EqnSource true;
    // fEqnSource true;
  }

}

